<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>BotAimImprover</RootNamespace>
    <AssemblyName>BotAimImprover</AssemblyName>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CounterStrikeSharp.API" Version="1.0.371" />
    <Reference Include="RayTraceApi">
      <HintPath>libs/RayTraceApi.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
