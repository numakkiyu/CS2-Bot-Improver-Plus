// skill templates

Template ProTop
    Skill = 100
	ReactionTime = 0
	AttackDelay = 0
	AimFocusInitial = 0
	AimFocusDecay = 0.0000001
	AimFocusOffsetScale = 0
	AimfocusInterval = 0
	Difficulty = EXPERT+HARD+NORMAL+EASY
End

Template ProFast   // sniper rifler rusher
	Skill = 100
	ReactionTime = 0
	AttackDelay = 0
	AimFocusInitial = 0
	AimFocusDecay = 0.001
	AimFocusOffsetScale = 0
	AimfocusInterval = 0
	Difficulty = EXPERT+HARD+NORMAL+EASY
End

Template ProPrecise   // sniper scoper fastshot camper
	Skill = 100
	ReactionTime = 0.01
	AttackDelay = 0
	AimFocusInitial = 0
	AimFocusDecay = 0.0000001
	AimFocusOffsetScale = 0
	AimfocusInterval = 0
	Difficulty = EXPERT+HARD+NORMAL+EASY
End

Template ProSlow    // duelist sniper
	Skill = 100
    ReactionTime = 0.01
    AttackDelay = 0
    AimFocusInitial = 0.00000001
	AimFocusDecay = 0.00000001
	AimFocusOffsetScale = 0
	AimfocusInterval = 0.00000001
	Difficulty = EXPERT+HARD+NORMAL+EASY
End

Template ProSteady    // rifler
    Skill = 100
    ReactionTime = 0.0001
    AttackDelay = 0
    AimFocusInitial = 0.0001
	AimFocusDecay = 0.0001
	AimFocusOffsetScale = 0
	AimfocusInterval = 0.0001
    Difficulty = EXPERT+HARD+NORMAL+EASY
End

Template RankRifler    // rifler
	Skill = 49
	ReactionTime = 0.2
	AttackDelay = 0.01
	VoicePitch = 85
	AimFocusInitial = 0.01
	AimFocusDecay = 1
	AimFocusOffsetScale = 0
	AimfocusInterval = 0.01
	Difficulty = EXPERT+HARD+NORMAL+EASY
End

Template RankDuelist    // duelist rusher
	Skill = 49
	ReactionTime = 0.2
	AttackDelay = 0
	AimFocusInitial = 0.25
	AimFocusDecay = 0.05
	AimFocusOffsetScale = 0
	AimfocusInterval = 0.05
	Difficulty = EXPERT+HARD+NORMAL+EASY
End

Template RankOthers    // sniper scoper rifler
    Skill = 49
    ReactionTime = 0.1
    AttackDelay = 0
    AimFocusInitial = 0.00001
	AimFocusDecay = 0.0000001
	AimFocusOffsetScale = 0.0000000000000000000000001
	AimfocusInterval = 0.0000000000001
    Difficulty = EXPERT+HARD+NORMAL+EASY
End


